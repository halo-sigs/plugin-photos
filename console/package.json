{
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild build --env-mode development --watch",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "prettier": "prettier --write './src/**/*.{vue,js,jsx,ts,tsx,css,scss,json,yml,yaml,html}'",
    "type-check": "vue-tsc --noEmit -p tsconfig.json --composite false",
    "test:unit": "echo 'No unit tests yet'"
  },
  "prettier": {
    "endOfLine": "lf",
    "plugins": [
      "prettier-plugin-organize-imports"
    ],
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false
  },
  "dependencies": {
    "@formkit/core": "1.0.0-beta.12",
    "@halo-dev/api-client": "^2.24.0",
    "@halo-dev/components": "^2.24.0",
    "@halo-dev/ui-shared": "^2.24.0",
    "@tanstack/vue-query": "^4.44.0",
    "@vueuse/core": "^10.11.1",
    "@vueuse/router": "^10.11.1",
    "axios": "^1.15.2",
    "es-toolkit": "^1.46.1",
    "fuse.js": "^6.6.2",
    "vue": "^3.5.33",
    "vue-draggable-plus": "^0.6.1"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "^2.24.0",
    "@iconify-json/ri": "^1.2.10",
    "@rsbuild/core": "^2.0.3",
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/node": "^24.12.2",
    "@unocss/eslint-config": "^66.6.8",
    "@unocss/webpack": "^66.6.8",
    "@vue/compiler-sfc": "^3.5.33",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~5.9.3",
    "unocss": "^66.6.8",
    "unplugin-icons": "^23.0.1",
    "vue-tsc": "^3.2.7"
  },
  "packageManager": "pnpm@10.33.2"
}
